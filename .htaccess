Options -MultiViews
DirectoryIndex index.html

RewriteEngine On

# Redirect /index.html to the domain root.
RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
RewriteRule ^index\.html$ / [R=301,L]

# Redirect the old legacy redirect page to the domain root.
RewriteCond %{THE_REQUEST} \s/+brillbrains\.html[\s?] [NC]
RewriteRule ^brillbrains\.html$ / [R=301,L]
RewriteRule ^brillbrains/?$ / [R=301,L]

# Redirect visible .html page URLs to clean URLs.
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^(.+)\.html$ /$1/ [R=301,L]

# Remove trailing slash from clean page URLs when it is not a real directory.
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)/$ /$1 [R=301,L]

# Serve extensionless page URLs from their .html files.
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]
